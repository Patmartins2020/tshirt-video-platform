generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  creator
  customer
  admin
}


enum ProductType {
  tshirt
  hoodie
  cap
  mug
  tote
}

enum ProductStatus {
  draft
  published
  archived
}

enum VideoType {
  tiktok
  instagram
  youtube_short
}

enum VideoStatus {
  processing
  ready
  failed
}

enum OrderStatus {
  pending
  paid
  processing
  shipped
  delivered
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum PayoutStatus {
  pending
  available
  paid
  failed
}

model User {
  id              String           @id @default(cuid())
  fullName        String
  email           String           @unique
  passwordHash    String
  username        String           @unique
  role            UserRole         @default(customer)
  country         String?
  currency        String?
  createdAt       DateTime         @default(now())

  creatorProfile  CreatorProfile?
  designs         Design[]
  products        Product[]
  stores          Store[]
  videos          Video[]
  customerOrders  Order[]          @relation("CustomerOrders")
  creatorOrders   Order[]          @relation("CreatorOrders")
  earnings        Earnings[]
  payouts         Payout[]
}

model CreatorProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  brandName      String
  bio            String?
  profileImage   String?
  bannerImage    String?
  socialLinks    Json?
  payoutMethod   String?
  payoutDetails  Json?
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Design {
  id            String    @id @default(cuid())
  userId        String
  title         String
  description   String?
  price         Float     @default(0)
  imageUrl      String?
  designType    String
  designFileUrl String?
  previewUrl    String?
  fontData      Json?
  colorData     Json?
  positionData  Json?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products      Product[]
}

model Product {
  id             String        @id @default(cuid())
  userId         String
  designId       String
  productType    ProductType
  title          String
  description    String?
  price          Float
  costPrice      Float?
  profitMargin   Float?
  status         ProductStatus @default(draft)
  createdAt      DateTime      @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  design         Design        @relation(fields: [designId], references: [id], onDelete: Cascade)
  variants       ProductVariant[]
  videos         Video[]
  orderItems     OrderItem[]
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  size          String?
  color         String?
  sku           String?  @unique
  stockStatus   String?
  mockupUrl     String?

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Store {
  id              String   @id @default(cuid())
  userId          String
  storeName       String
  slug            String   @unique
  description     String?
  logoUrl         String?
  themeSettings   Json?
  featuredVideoId String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Video {
  id            String      @id @default(cuid())
  userId        String
  productId     String
  templateName  String
  videoType     VideoType
  scriptText    String?
  captionText   String?
  musicOption   String?
  status        VideoStatus @default(processing)
  videoUrl      String?
  thumbnailUrl  String?
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id               String        @id @default(cuid())
  customerId       String
  creatorId        String
  totalAmount      Float
  currency         String
  orderStatus      OrderStatus   @default(pending)
  shippingName     String
  shippingAddress  String
  paymentStatus    PaymentStatus @default(pending)
  createdAt        DateTime      @default(now())

  customer         User          @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  creator          User          @relation("CreatorOrders", fields: [creatorId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  payments         Payment[]
  earnings         Earnings[]
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  variantId    String?
  quantity     Int
  unitPrice    Float
  totalPrice   Float

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  userId          String
  paymentGateway  String
  transactionId   String?       @unique
  amount          Float
  currency        String
  status          PaymentStatus @default(pending)
  paidAt          DateTime?

  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Earnings {
  id             String       @id @default(cuid())
  creatorId      String
  orderId        String
  grossAmount    Float
  printCost      Float
  platformFee    Float
  creatorProfit  Float
  payoutStatus   PayoutStatus @default(pending)
  createdAt      DateTime     @default(now())

  creator        User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payout {
  id               String       @id @default(cuid())
  creatorId        String
  amount           Float
  payoutMethod     String
  payoutReference  String?
  status           PayoutStatus @default(pending)
  requestedAt      DateTime     @default(now())
  paidAt           DateTime?

  creator          User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}